root = true

[*]
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
charset = utf-8
indent_style = space
indent_size = 4

[*.{md,markdown}]
trim_trailing_whitespace = false

[*.{yml,yaml,json,jsonc}]
indent_size = 2

[*.{html,htm,css,scss,js,ts,vue}]
indent_size = 2

[Makefile]
indent_style = tab
